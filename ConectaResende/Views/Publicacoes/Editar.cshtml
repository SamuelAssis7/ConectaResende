@model ConectaResende.Models.Publicacao

<style>
    :root {
        --bg-dark: #020617;
        --accent-blue: #3b82f6;
        --electric-blue: #60a5fa;
        --glass-bg: rgba(15, 23, 42, 0.8);
        --border-glow: rgba(59, 130, 246, 0.2);
    }

    body {
        background-color: var(--bg-dark);
        background-image: radial-gradient(circle at 10% 10%, rgba(59, 130, 246, 0.05) 0%, transparent 40%), radial-gradient(circle at 90% 90%, rgba(59, 130, 246, 0.05) 0%, transparent 40%);
        color: #f8fafc;
        font-family: 'Inter', sans-serif;
    }

    .badge-hero {
        background: linear-gradient(90deg, rgba(59,130,246,0.2) 0%, transparent 100%);
        color: var(--electric-blue);
        border-left: 3px solid var(--accent-blue);
        padding: 6px 16px;
        font-size: 0.7rem;
        letter-spacing: 2px;
        text-transform: uppercase;
        display: inline-block;
    }

    .form-card {
        background: var(--glass-bg);
        backdrop-filter: blur(20px);
        border: 1px solid var(--border-glow);
        border-radius: 0px 40px 0px 40px;
        padding: 50px;
        box-shadow: 0 0 50px rgba(0,0,0,0.5);
        position: relative;
        overflow: hidden;
    }

        .form-card::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 2px;
            background: linear-gradient(90deg, transparent, var(--accent-blue), transparent);
        }

    .form-label {
        color: var(--electric-blue);
        font-weight: 800;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        margin-bottom: 10px;
        display: block;
    }

    .form-control, .form-select {
        background: rgba(0, 0, 0, 0.4) !important;
        border: 1px solid rgba(255, 255, 255, 0.1) !important;
        color: #fff !important;
        border-radius: 8px;
        padding: 14px;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

        .form-control:focus {
            border-color: var(--accent-blue) !important;
            box-shadow: 0 0 15px rgba(59, 130, 246, 0.3) !important;
            outline: none;
        }

    .btn-save {
        background: var(--accent-blue);
        color: white;
        border: none;
        padding: 16px 40px;
        border-radius: 4px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 2px;
        clip-path: polygon(10% 0%, 100% 0%, 90% 100%, 0% 100%);
        transition: all 0.3s;
        cursor: pointer;
    }

        .btn-save:hover {
            background: #2563eb;
            box-shadow: -10px 0 20px rgba(59, 130, 246, 0.4);
        }

    .btn-cancel {
        color: #64748b;
        text-decoration: none;
        font-weight: 700;
        font-size: 0.9rem;
        text-transform: uppercase;
        transition: 0.3s;
    }

        .btn-cancel:hover {
            color: #ef4444;
        }

    .section-title {
        font-size: 2.5rem;
        font-weight: 900;
        letter-spacing: -2px;
        background: linear-gradient(to bottom, #fff 40%, #64748b);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }
</style>

<div class="container py-5 mt-3">
    <div class="row justify-content-center">
        <div class="col-lg-8">

            <div class="mb-5 text-center text-md-start">
                <span class="badge-hero mb-3">System Update // Edição</span>
                <h2 class="section-title text-uppercase">Editar Publicação</h2>
            </div>

            <div class="form-card">
                <form asp-action="Editar" method="post">

                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="EmailUsuario" />
                    @if (Model != null)
                    {
                        <input type="hidden" asp-for="DataPublicacao" />
                    }

                    <div class="row">
                        <div class="col-12 mb-4">
                            <label class="form-label">Título</label>
                            <input asp-for="Titulo" class="form-control" />
                        </div>

                        <div class="col-md-6 mb-4">
                            <label class="form-label">Categoria</label>
                            <select asp-for="Tipo" class="form-select">
                                <option value="Emprego">Emprego</option>
                                <option value="Curso">Curso</option>
                                <option value="Ação Social">Ação Social</option>
                            </select>
                        </div>

                        <div class="col-md-6 mb-4">
                            <label class="form-label">Bairro</label>
                            <input asp-for="Bairro" class="form-control" />
                        </div>

                        <div class="col-12 mb-5">
                            <label class="form-label">Descrição</label>
                            <textarea asp-for="Descricao" class="form-control" rows="5"></textarea>
                        </div>

                        <div class="col-12 d-flex align-items-center justify-content-between">
                            <a asp-action="Minhas" class="btn-cancel">
                                Cancelar
                            </a>
                            <button type="submit" class="btn-save">
                                💾 Salvar Alterações
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>