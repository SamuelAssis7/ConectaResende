@model ConectaResende.Models.Publicacao

<style>
    :root {
        --bg-dark: #020617;
        --accent-red: #ef4444;
        --electric-red: #f87171;
        --glass-bg: rgba(15, 23, 42, 0.8);
        --border-glow: rgba(239, 68, 68, 0.2);
    }

    body {
        background-color: var(--bg-dark);
        background-image: radial-gradient(circle at 10% 10%, rgba(239, 68, 68, 0.05) 0%, transparent 40%), radial-gradient(circle at 90% 90%, rgba(239, 68, 68, 0.05) 0%, transparent 40%);
        color: #f8fafc;
        font-family: 'Inter', sans-serif;
    }

    .badge-hero {
        background: linear-gradient(90deg, rgba(239, 68, 68, 0.2) 0%, transparent 100%);
        color: var(--electric-red);
        border-left: 3px solid var(--accent-red);
        padding: 6px 16px;
        font-size: 0.7rem;
        letter-spacing: 2px;
        text-transform: uppercase;
        display: inline-block;
    }

    .form-card {
        background: var(--glass-bg);
        backdrop-filter: blur(20px);
        border: 1px solid var(--border-glow);
        border-radius: 40px 0px 40px 0px; /* Corte agressivo invertido para diferenciar da edição */
        padding: 50px;
        box-shadow: 0 0 50px rgba(0,0,0,0.5);
        position: relative;
        overflow: hidden;
    }

        .form-card::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 2px;
            background: linear-gradient(90deg, transparent, var(--accent-red), transparent);
        }

    .warning-box {
        background: rgba(239, 68, 68, 0.05);
        border: 1px solid rgba(239, 68, 68, 0.1);
        border-radius: 12px;
        padding: 20px;
        margin-bottom: 30px;
    }

    .pub-title-preview {
        color: #fff;
        font-weight: 800;
        font-size: 1.4rem;
        margin-bottom: 10px;
        display: block;
    }

    .pub-desc-preview {
        color: #94a3b8;
        font-size: 0.95rem;
        line-height: 1.6;
    }

    .btn-delete-final {
        background: var(--accent-red);
        color: white;
        border: none;
        padding: 16px 40px;
        border-radius: 4px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 2px;
        clip-path: polygon(10% 0%, 100% 0%, 90% 100%, 0% 100%);
        transition: all 0.3s;
        cursor: pointer;
    }

        .btn-delete-final:hover {
            background: #b91c1c;
            box-shadow: 0 0 20px rgba(239, 68, 68, 0.4);
            transform: scale(1.05);
        }

    .btn-cancel {
        color: #64748b;
        text-decoration: none;
        font-weight: 700;
        font-size: 0.9rem;
        text-transform: uppercase;
        transition: 0.3s;
    }

        .btn-cancel:hover {
            color: #fff;
        }

    .section-title {
        font-size: 2.5rem;
        font-weight: 900;
        letter-spacing: -2px;
        background: linear-gradient(to bottom, #fff 40%, var(--accent-red));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }
</style>

<div class="container py-5 mt-3">
    <div class="row justify-content-center">
        <div class="col-lg-8">

            <div class="mb-5 text-center text-md-start">
                <span class="badge-hero mb-3">System Alert // Exclusão</span>
                <h2 class="section-title text-uppercase">Remover Publicação</h2>
            </div>

            <div class="form-card text-center text-md-start">
                <p class="text-uppercase fw-bold mb-4" style="color: var(--electric-red); letter-spacing: 1px;">
                    <i class="fa-solid fa-triangle-exclamation me-2"></i> Atenção: Esta ação não pode ser desfeita.
                </p>

                <div class="warning-box">
                    <span class="pub-title-preview">@Model.Titulo</span>
                    <p class="pub-desc-preview">@Model.Descricao</p>
                </div>

                <form asp-action="Excluir" method="post">
                    <input type="hidden" asp-for="Id" />

                    <div class="d-flex align-items-center justify-content-between flex-wrap gap-4">
                        <a asp-action="Minhas" class="btn-cancel">
                            [ Abortar Missão ]
                        </a>

                        <button type="submit" class="btn-delete-final">
                            <i class="fa-solid fa-trash-can me-2"></i> Confirmar Exclusão _
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>