<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - Conecta Resende</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;800&display=swap" rel="stylesheet">

    <style>

        :root {
            --bg-dark: #030712;
            --glass: rgba(255,255,255,0.03);
            --glass-border: rgba(255,255,255,0.08);
            --accent-blue: #3b82f6;
            --text-muted: #9ca3af;
        }

        /* ================= BODY ================= */

        body {
            background-color: var(--bg-dark);
            color: #f3f4f6;
            font-family: 'Inter',sans-serif;
            margin: 0;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            -webkit-font-smoothing: antialiased;
        }

        /* ================= PAGE CONTENT ================= */

        .page-content {
            flex: 1;
            margin-top: 90px;
        }

        /* ================= NAVBAR ================= */

        .navbar {
            background: rgba(3,7,18,0.8) !important;
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
            border-bottom: 1px solid var(--glass-border);
            padding: 18px 0;
            transition: all .25s ease;
        }

        .navbar-brand {
            font-size: 1.5rem;
            font-weight: 800;
            letter-spacing: -1px;
            background: linear-gradient(to right,#fff,#6b7280);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        /* ===== MENU ===== */

        .nav-item-custom {
            color: var(--text-muted);
            font-weight: 500;
            margin-right: 22px;
            text-decoration: none;
            font-size: .95rem;
            transition: .25s;
            position: relative;
        }

            .nav-item-custom:hover {
                color: var(--accent-blue);
            }

            /* Linha animada */

            .nav-item-custom::after {
                content: "";
                position: absolute;
                width: 0%;
                height: 2px;
                bottom: -6px;
                left: 0;
                background: var(--accent-blue);
                transition: .25s;
            }

            .nav-item-custom:hover::after {
                width: 100%;
            }

        /* ================= BOTÕES ================= */

        .btn-login {
            color: #fff;
            border: 1px solid var(--glass-border);
            background: var(--glass);
            padding: 8px 24px;
            border-radius: 10px;
            font-weight: 600;
            font-size: .9rem;
            text-decoration: none;
            transition: .25s;
        }

            .btn-login:hover {
                background: rgba(255,255,255,0.08);
                border-color: rgba(255,255,255,0.3);
                color: #fff;
            }

        /* ===== REGISTER ===== */

        .btn-register {
            background: var(--accent-blue);
            color: white;
            padding: 8px 24px;
            border-radius: 10px;
            font-weight: 600;
            font-size: .9rem;
            border: none;
            text-decoration: none;
            box-shadow: 0 8px 20px rgba(59,130,246,.35);
            transition: .25s;
            margin-left: 12px;
        }

            .btn-register:hover {
                transform: translateY(-2px);
                box-shadow: 0 12px 25px rgba(59,130,246,.55);
                color: white;
            }

        /* ================= FOOTER ================= */

        .footer {
            background: linear-gradient(to top,#000 0%,var(--bg-dark) 100%);
            border-top: 1px solid var(--glass-border);
            padding: 60px 0 30px;
            margin-top: 100px;
        }

        /* ===== BRAND ===== */

        .footer-brand {
            font-size: 1.4rem;
            font-weight: 800;
            color: #fff;
            text-decoration: none;
            letter-spacing: -0.5px;
        }

        /* ===== TEXT ===== */

        .footer-text {
            color: var(--text-muted);
            font-size: .95rem;
            line-height: 1.6;
        }

        /* ===== LINKS ===== */

        .footer-link {
            color: var(--text-muted);
            text-decoration: none;
            transition: .25s;
            font-size: .9rem;
        }

            .footer-link:hover {
                color: var(--accent-blue);
            }

        /* ===== SOCIAL ===== */

        .social-box {
            display: flex;
            gap: 12px;
        }

        .social-icon {
            width: 40px;
            height: 40px;
            background: var(--glass);
            border: 1px solid var(--glass-border);
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 10px;
            color: #fff;
            transition: .25s;
            text-decoration: none;
        }

            .social-icon:hover {
                background: var(--accent-blue);
                border-color: var(--accent-blue);
                transform: translateY(-3px);
                color: white;
            }

        /* ===== FOOTER BOTTOM ===== */

        .footer-bottom {
            border-top: 1px solid var(--glass-border);
            margin-top: 40px;
            padding-top: 25px;
            color: #4b5563;
            font-size: .85rem;
        }

        /* Remove o comportamento nativo que causa o tranco */
        html {
            scroll-behavior: auto !important;
        }

        #recentes {
            scroll-margin-top: 110px;
            /* Adiciona um fade-in nos cards quando a seção é carregada */
            animation: fadeInSection 0.8s ease-out;
        }

        @@keyframes fadeInSection {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .fw-black {
            font-weight: 900;
            letter-spacing: -1px;
        }

        .accordion-button:not(.collapsed) {
            background-color: rgba(59, 130, 246, 0.05);
            color: #3b82f6;
        }

        .content-legal p {
            font-size: 1.05rem;
            line-height: 1.7;
        }


    </style>

</head>

<body>

    <!-- ================= NAVBAR ================= -->

    <nav class="navbar navbar-expand-lg fixed-top">

        <div class="container">

            <a class="navbar-brand" asp-controller="Home" asp-action="Index">

                <i class="fa-solid fa-bolt me-2" style="color:#3b82f6"></i>

                ConectaResende

            </a>

            <button class="navbar-toggler border-0 shadow-none"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#menu">

                <span class="navbar-toggler-icon" style="filter:invert(1);"></span>

            </button>

            <div class="collapse navbar-collapse" id="menu">

                <div class="navbar-nav mx-auto">
                    <a class="nav-item-custom" asp-controller="Home" asp-action="Index" asp-fragment="recentes">
                        Publicações
                    </a>

                    <a class="nav-item-custom" asp-controller="Home" asp-action="Index" asp-route-tipo="Emprego" asp-fragment="recentes">
                        Empregos
                    </a>

                    <a class="nav-item-custom" asp-controller="Home" asp-action="Index" asp-route-tipo="Curso" asp-fragment="recentes">
                        Cursos
                    </a>

                    <a class="nav-item-custom" asp-controller="Home" asp-action="Index" asp-route-tipo="acao" asp-fragment="recentes">
                        Ações Sociais
                    </a>
                </div>

                <!-- Área direita -->
                <div class="navbar-nav ms-auto align-items-center mt-3 mt-lg-0">

                    @if (User.Identity.IsAuthenticated)
                    {

                        <a class="btn-register me-3"
                           asp-controller="Publicacoes"
                           asp-action="Criar">

                            <i class="fa-solid fa-plus me-1"></i>
                            Criar Publicação

                        </a>

                        <a class="nav-item-custom me-3"
                           asp-controller="Publicacoes"
                           asp-action="Minhas">

                            Minhas Publicações

                        </a>

                        <div class="dropdown">

                            <button class="btn-login dropdown-toggle"
                                    data-bs-toggle="dropdown">

                                <i class="fa-solid fa-user me-2"></i>
                                @User.Identity.Name

                            </button>

                            <ul class="dropdown-menu dropdown-menu-end">

                                <li>

                                    <a class="dropdown-item" asp-controller="Perfil" asp-action="Index">
                                        Meu Perfil
                                    </a>

                                </li>

                                <li><hr class="dropdown-divider"></li>

                                <li>

                                    <a class="dropdown-item text-danger"
                                       asp-controller="Auth"
                                       asp-action="Logout">

                                        Sair

                                    </a>

                                </li>

                            </ul>

                        </div>

                    }
                    else
                    {

                        <a class="btn-login"
                           asp-controller="Auth"
                           asp-action="Login">

                            Entrar

                        </a>

                        <a class="btn-register"
                           asp-controller="Auth"
                           asp-action="Registrar">

                            Criar Conta

                        </a>

                    }

                </div>

            </div>

        </div>

    </nav>

    <!-- ================= PAGE ================= -->

    <div class="page-content">

        @RenderBody()

    </div>

    <!-- ================= FOOTER ================= -->

    <footer class="footer">

        <div class="container">

            <div class="row gy-5">

                <div class="col-lg-5">

                    <a class="footer-brand mb-3 d-block" href="#">

                        <i class="fa-solid fa-bolt me-2" style="color:#3b82f6"></i>

                        ConectaResende

                    </a>

                    <p class="footer-text pe-lg-5">

                        Conectando talentos às melhores oportunidades de Resende.
                        Nossa missão é fortalecer a economia local através da educação, emprego e impacto social.

                    </p>

                    <div class="social-links d-flex gap-3 mt-4">
                        <a href="https://wa.me/5524998813660" target="_blank" class="social-icon-box"><i class="fa-brands fa-whatsapp"></i></a>
                        <a href="https://www.linkedin.com/in/samuel-assis-529550302/" target="_blank" class="social-icon-box"><i class="fa-brands fa-linkedin-in"></i></a>
                        <a href="https://github.com/SamuelAssis7" target="_blank" class="social-icon-box"><i class="fa-brands fa-github"></i>
                        </a>
                    </div>

                </div>

                <div class="col-lg-3 ms-auto">

                    <h6 class="text-white fw-bold mb-4">

                        Suporte & Contato

                    </h6>

                    <ul class="list-unstyled">

                        <li class="mb-2">
                            <a asp-controller="Home" asp-action="CentralAjuda" class="footer-link">
                                Central de Ajuda
                            </a>
                        </li>

                        <li class="mb-2">
                            <a asp-controller="Home" asp-action="TermosUso" class="footer-link">
                                Termos de Uso
                            </a>
                        </li>

                        <li class="mb-2">
                            <a asp-controller="Home" asp-action="Privacidade" class="footer-link">
                                Política de Privacidade
                            </a>
                        </li>

                        <li class="mb-2">

                            <a href="https://mail.google.com/mail/?view=cm&fs=1&to=contato@conectaresende.com&su=Contato%20via%20ConectaResende"
                               class="footer-link"
                               style="color: #3b82f6; font-weight: 600;"
                               target="_blank">
                                samuelmagno817@gmail.com
                            </a>


                        </li>

                    </ul>

                </div>

            </div>

            <div class="footer-bottom d-flex flex-column flex-md-row justify-content-between align-items-center">

                <div class="text-center text-md-start mb-2 mb-md-0">

                    © 2026 Conecta Resende. Todos os direitos reservados.

                </div>

                <div class="text-center text-md-end">

                    Feito com

                    <i class="fa-solid fa-heart text-danger mx-1"></i>

                    para a nossa cidade.

                </div>

            </div>

        </div>

    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        function smoothScrollTo(targetSelector, duration = 1000) {
            const target = document.querySelector(targetSelector);
            if (!target) return;

            const targetPosition = target.getBoundingClientRect().top + window.pageYOffset - 110; // 110 é o desconto da navbar
            const startPosition = window.pageYOffset;
            const distance = targetPosition - startPosition;
            let startTime = null;

            function animation(currentTime) {
                if (startTime === null) startTime = currentTime;
                const timeElapsed = currentTime - startTime;

                // Função de Easing: EaseInOutCubic (Começa devagar, acelera, termina devagar)
                const run = easeInOutCubic(timeElapsed, startPosition, distance, duration);

                window.scrollTo(0, run);
                if (timeElapsed < duration) requestAnimationFrame(animation);
            }

            function easeInOutCubic(t, b, c, d) {
                t /= d / 2;
                if (t < 1) return c / 2 * t * t * t + b;
                t -= 2;
                return c / 2 * (t * t * t + 2) + b;
            };

            requestAnimationFrame(animation);
        }

        // Dispara o scroll suave ao carregar a página se houver #recentes na URL
        window.addEventListener('load', () => {
            if (window.location.hash === '#recentes') {
                // Pequeno delay para a página estabilizar antes de começar o deslize
                setTimeout(() => {
                    smoothScrollTo('#recentes', 1200); // 1200ms para um deslize bem elegante
                }, 200);
            }
        });
    </script>

</body>
</html>