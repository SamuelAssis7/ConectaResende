@model ConectaResende.Models.Usuario

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Cadastro - Conecta Resende</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">

    <style>
        :root {
            --bg-dark: #030712;
            --card-glass: rgba(17, 24, 39, 0.7);
            --glass-border: rgba(255, 255, 255, 0.08);
            --accent-blue: #3b82f6;
            --accent-yellow: #f59e0b;
        }

        body {
            background-color: var(--bg-dark);
            background-image: radial-gradient(circle at 50% -20%, rgba(59, 130, 246, 0.15) 0%, transparent 50%);
            font-family: 'Inter', sans-serif;
            color: white;
            min-height: 100vh;
            margin: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .register-card {
            width: 100%;
            max-width: 480px;
            background: var(--card-glass);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid var(--glass-border);
            border-radius: 32px;
            padding: 40px;
            box-shadow: 0 40px 100px rgba(0, 0, 0, 0.8);
        }

        .brand-logo {
            font-size: 1.8rem;
            font-weight: 800;
            text-align: center;
            margin-bottom: 8px;
            letter-spacing: -1px;
        }

        .brand-resende {
            color: var(--accent-yellow);
        }

        /* TEXTO CORRIGIDO PARA LEITURA */
        .sub-header {
            color: rgba(255, 255, 255, 0.7); /* Brancos levemente transparente para contraste */
            font-size: 0.9rem;
            text-align: center;
            margin-bottom: 30px;
        }

        .input-group-custom {
            margin-bottom: 18px;
        }

        .input-label {
            display: block;
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--accent-blue);
            margin-bottom: 8px;
        }

        .custom-input, .custom-select {
            width: 100%;
            background: rgba(0, 0, 0, 0.3);
            border: 1px solid var(--glass-border);
            border-radius: 14px;
            padding: 12px 18px;
            color: white;
            transition: all 0.3s ease;
        }

            .custom-input:focus, .custom-select:focus {
                outline: none;
                border-color: var(--accent-blue);
                box-shadow: 0 0 15px rgba(59, 130, 246, 0.2);
                background: rgba(0, 0, 0, 0.4);
            }

        /* Ajuste para o texto dentro do select */
        option {
            background-color: var(--bg-dark);
            color: white;
        }

        .btn-register {
            width: 100%;
            background: var(--accent-yellow);
            color: black;
            border: none;
            padding: 16px;
            border-radius: 16px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: 0.3s cubic-bezier(0.165, 0.84, 0.44, 1);
            margin-top: 15px;
        }

            .btn-register:hover {
                transform: translateY(-2px);
                box-shadow: 0 10px 20px rgba(245, 158, 11, 0.3);
                background: #eab308;
            }

        .footer-links {
            text-align: center;
            margin-top: 25px;
            font-size: 0.9rem;
            color: #94a3b8;
        }

            .footer-links a {
                color: white;
                text-decoration: none;
                font-weight: 600;
                transition: 0.3s;
            }

                .footer-links a:hover {
                    color: var(--accent-blue);
                }

        .back-home {
            position: absolute;
            top: 30px;
            left: 30px;
            color: #64748b;
            text-decoration: none;
            font-weight: 600;
            font-size: 0.9rem;
        }
    </style>
</head>
<body>

    <a href="/" class="back-home">
        <i class="fa-solid fa-arrow-left me-2"></i> Voltar
    </a>

    <div class="register-card">
        <div class="brand-logo">
            Conecta <span class="brand-resende">Resende</span>
        </div>
        <p class="sub-header">Junte-se à nossa comunidade agora</p>

        <form asp-action="Registrar" method="post">
            <div class="input-group-custom">
                <label class="input-label">Nome Completo</label>
                <input asp-for="Nome" class="custom-input" placeholder="Seu nome ou Razão Social" required />
            </div>

            <div class="input-group-custom">
                <label class="input-label">E-mail</label>
                <input asp-for="Email" type="email" class="custom-input" placeholder="exemplo@email.com" required />
            </div>

            <div class="input-group-custom">
                <label class="input-label">Senha</label>
                <input asp-for="Senha" type="password" class="custom-input" placeholder="••••••••" required />
            </div>

            <div class="input-group-custom">
                <label class="input-label">Tipo de Usuário</label>
                <select asp-for="TipoUsuario" class="custom-select" required>
                    <option value="" disabled selected>Escolha uma opção</option>
                    <option value="Morador">👤 Morador</option>
                    <option value="Instituicao">🏢 Instituição / Empresa</option>
                </select>
            </div>

            <button type="submit" class="btn-register">
                Criar minha conta
            </button>

            <div class="footer-links">
                Já faz parte? <a asp-action="Login">Acesse sua conta</a>
            </div>
        </form>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    @if (TempData["Sucesso"] != null)
    {
        <script>
            Swal.fire({
                icon: 'success',
                title: 'Conta criada com sucesso!',
                showConfirmButton: false,
                timer: 2000
            });

            setTimeout(function(){
                window.location.href='/Auth/Login';
            },2000);

        </script>
    }

</body>
</html>